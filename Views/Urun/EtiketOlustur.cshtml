@model IEnumerable<LordMarket.Models.Urunler>
@{
    ViewBag.Title = "Etiketler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container-fluid px-4">

    <h3 class="mb-3">Etiket Oluştur</h3>

    @using (Html.BeginForm("EtiketOlusturPDF", "Urun", FormMethod.Post))
    {
        <!-- ÜST BAR -->
        <div class="d-flex flex-wrap gap-2 mb-3">

            <!-- KATEGORİ -->
            <select id="kategoriFilter" class="form-select w-auto">
                <option value="">Tüm Kategoriler</option>
                @foreach (var k in ViewBag.Kategoriler)
                {
                    <option value="@k" @(ViewBag.SeciliKategori == k ? "selected" : "")>@k</option>
                }
            </select>

            <!-- ARAMA -->
            <input type="text" id="urunSearch" class="form-control w-auto" placeholder="Ara..." />

            <!-- BUTONLAR -->
            <button type="button" id="tumunuSecBtn" class="btn btn-outline-primary">Tümünü Seç</button>

            <button type="submit" class="btn btn-danger ms-auto">
                PDF Oluştur
            </button>
        </div>

        <!-- SEÇİLEN SAYISI -->
        <div class="mb-2">
            <b>Seçilen Ürün:</b> <span id="seciliAdet">0</span>
        </div>

        <!-- ÜRÜN LİSTESİ -->
        <div class="row" id="urunListesi">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-2 urun-item"
                     data-kategori="@item.UrunKategori"
                     data-urunad="@item.UrunAd.ToLower()"
                     data-barkod="@item.Barkod">

                    <div class="card p-2">
                        <input type="checkbox" class="form-check-input me-2"
                               name="seciliUrunler" value="@item.ID" />

                        <b>@item.UrunAd</b>
                        <small>@item.UrunKategori</small>
                        <span>@item.UrunFiyat ₺</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    // KATEGORİ FİLTRE
    document.getElementById('kategoriFilter').addEventListener('change', function () {
        const kategori = this.value;
        window.location.href = kategori ? `?kategori=${kategori}` : window.location.pathname;
    });

    // ARAMA
    document.getElementById('urunSearch').addEventListener('input', function () {
        const val = this.value.toLowerCase();

        document.querySelectorAll('.urun-item').forEach(item => {
            const ad = item.dataset.urunad;
            const barkod = item.dataset.barkod;

            item.style.display =
                (ad.includes(val) || barkod.includes(val)) ? 'block' : 'none';
        });
    });

    // TÜMÜNÜ SEÇ
    let tumSecili = false;
    document.getElementById('tumunuSecBtn').onclick = function () {
        document.querySelectorAll('input[type=checkbox]').forEach(cb => cb.checked = !tumSecili);
        tumSecili = !tumSecili;
        sayacGuncelle();
    };

    // KATEGORİYE GÖRE SEÇ
    document.getElementById('kategoriSecBtn').onclick = function () {
        const kategori = document.getElementById('kategoriFilter').value;

        if (!kategori) {
            alert("Kategori seç!");
            return;
        }

        document.querySelectorAll('.urun-item').forEach(item => {
            if (item.dataset.kategori === kategori)
                item.querySelector('input').checked = true;
        });

        sayacGuncelle();
    };

    // SADECE SEÇİLENLER
    let sadeceSecili = false;
    document.getElementById('seciliGosterBtn').onclick = function () {
        sadeceSecili = !sadeceSecili;

        document.querySelectorAll('.urun-item').forEach(item => {
            const checked = item.querySelector('input').checked;
            item.style.display = (sadeceSecili && !checked) ? 'none' : 'block';
        });
    };

    // SEÇİM SAYACI
    document.querySelectorAll('input[type=checkbox]').forEach(cb => {
        cb.addEventListener('change', sayacGuncelle);
    });

    function sayacGuncelle() {
        const count = document.querySelectorAll('input[type=checkbox]:checked').length;
        document.getElementById('seciliAdet').innerText = count;
    }
</script>